plans/
.restore_progress

# Python 字节码缓存
__pycache__/
*.pyc

# searxng: 密钥文件（含 secret_key）
searxng/settings.yml

# searxng: Python 虚拟环境
searxng/venv/

# searxng: 原始开源项目
searxng/repo/

# 日志文件
*.log

# SQLite 数据库文件
*.db

# searxng: 运行时 PID 文件
searxng/searxng.pid


